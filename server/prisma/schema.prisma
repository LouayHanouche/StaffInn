generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  role         String
  email        String         @unique
  passwordHash String
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  hotel        Hotel?
  candidate    Candidate?
  sessions     Session[]

  @@index([role])
  @@map("users")
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Hotel {
  id          String     @id @default(cuid())
  userId      String     @unique
  name        String
  address     String
  description String?
  logoPath    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers      JobOffer[]

  @@map("hotels")
}

model Candidate {
  id              String        @id @default(cuid())
  userId          String        @unique
  fullName        String
  skills          String
  position        String
  experienceYears Int           @default(0)
  cvPath          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]

  @@index([experienceYears])
  @@index([position])
  @@index([skills])
  @@map("candidates")
}

model JobOffer {
  id                 String         @id @default(cuid())
  hotelId            String
  title              String
  description        String
  requiredSkills     String
  requiredExperience Int
  status             String         @default("PENDING")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  hotel              Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  applications       Application[]

  @@index([status])
  @@index([title])
  @@index([requiredSkills])
  @@map("job_offers")
}

model Application {
  id          String            @id @default(cuid())
  candidateId String
  jobOfferId  String
  status      String @default("PENDING")
  coverLetter String?
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOffer    JobOffer          @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobOfferId])
  @@index([status])
  @@map("applications")
}
